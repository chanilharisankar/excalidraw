      "boundElements": [],
      "updated": 1770084831243,
      "link": null,
      "locked": false,
      "text": "You place a taint on a node to say, \n\"I am restricted.\" By default, no pod \ncan be scheduled here unless \nit specifically says it can handle this taint.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "You place a taint on a node to say, \n\"I am restricted.\" By default, no pod \ncan be scheduled here unless \nit specifically says it can handle this taint.",
      "autoResize": true,
      "lineHeight": 1.25
    },
