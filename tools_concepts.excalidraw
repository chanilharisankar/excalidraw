    {
      "id": "GlnyKqad5FYFcYYJBC5WS",
      "type": "text",
      "x": 138.7072525024414,
      "y": 4237.8193359375,
      "width": 704,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
