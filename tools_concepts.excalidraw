    },
    {
      "id": "PRazVXswUYaRr1J82f2uU",
      "type": "text",
      "x": 2841.513753618513,
      "y": 735.814453125,
      "width": 627,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1v",
      "roundness": null,
      "seed": 478786088,
      "version": 256,
      "versionNonce": 219289384,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770256546899,
      "link": null,
      "locked": false,
      "text": "1. Leader -  follower\n    asynchronous replication - Not waiting for ACK\n    synchronous replication - wait for ACK from followers\n2. Leader less replication\n    ex: AWS dynamodb",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Leader -  follower\n    asynchronous replication - Not waiting for ACK\n    synchronous replication - wait for ACK from followers\n2. Leader less replication\n    ex: AWS dynamodb",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "_NeXyKCX-KCuFO4Qus57O",
