    },
    {
      "id": "_1A0Z2z5guLQJriVBNHlh",
      "type": "text",
      "x": 2859.5053210788296,
      "y": 1217.9090711805552,
      "width": 1133,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b20",
      "roundness": null,
      "seed": 1611214347,
      "version": 131,
      "versionNonce": 83662603,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770341482209,
      "link": null,
      "locked": false,
      "text": "SLI (Service Level Indicator): A specific metric that tells you how the system is doing right now.\nSLO (Service Level Objective): The target value or range for an SLI. This is your internal goal.\nSLA (Service Level Agreement): The legal contract with your customers. If you miss this, \n                               you usually have to pay money back.\n\nMTTF (Mean Time To Failure): How long a system runs before it breaks. (Used for non-repairable things).\nMTTR (Mean Time To Repair/Resolve): The average time it takes to fix a problem from the moment it \n                                started. This is the one DevOps engineers focus on most.\nMTTA (Mean Time To Acknowledge): How long it takes for a human to click \"Acknowledge\" \n                                on an alert (like in PagerDuty).\nMTBF (Mean Time Between Failures): The average time between one crash and the next.\nError Budget : How much time left from SLO after lets say 5min downtime \n\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SLI (Service Level Indicator): A specific metric that tells you how the system is doing right now.\nSLO (Service Level Objective): The target value or range for an SLI. This is your internal goal.\nSLA (Service Level Agreement): The legal contract with your customers. If you miss this, \n                               you usually have to pay money back.\n\nMTTF (Mean Time To Failure): How long a system runs before it breaks. (Used for non-repairable things).\nMTTR (Mean Time To Repair/Resolve): The average time it takes to fix a problem from the moment it \n                                started. This is the one DevOps engineers focus on most.\nMTTA (Mean Time To Acknowledge): How long it takes for a human to click \"Acknowledge\" \n                                on an alert (like in PagerDuty).\nMTBF (Mean Time Between Failures): The average time between one crash and the next.\nError Budget : How much time left from SLO after lets say 5min downtime \n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
