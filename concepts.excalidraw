      "text": "1. Leader -  follower\n    asynchronous replication - Not waiting for ACK\n    synchronous replication - wait for ACK from followers\n2. Leader less replication\n    ex: AWS dynamodb",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Leader -  follower\n    asynchronous replication - Not waiting for ACK\n    synchronous replication - wait for ACK from followers\n2. Leader less replication\n    ex: AWS dynamodb",
      "autoResize": true,
      "lineHeight": 1.25
    },
