      "link": null,
      "locked": false,
      "text": "nodeSelector - old way\nAffinity - Which pod will schedule based on node lebel\n    RequiredDuringSchedulingIgnoredDuringExecution\n    PreferredDuringSchedulingIgnoredDuringExecution\nPod Affinity - pods works together should stay near in same node\nPod anti-affinity - Don't put all your eggs in one basket\n \n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "nodeSelector - old way\nAffinity - Which pod will schedule based on node lebel\n    RequiredDuringSchedulingIgnoredDuringExecution\n    PreferredDuringSchedulingIgnoredDuringExecution\nPod Affinity - pods works together should stay near in same node\nPod anti-affinity - Don't put all your eggs in one basket\n \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
